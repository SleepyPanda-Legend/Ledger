// Ledger — Prisma schema
// Uses PostgreSQL for both local development and production.
// Local: set DATABASE_URL to a local Postgres instance or Neon/Supabase dev branch.
// Run: npx prisma db push  (first time)  |  npx prisma migrate dev (ongoing)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Auth models — required by Auth.js (next-auth v5) with Prisma adapter
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // null for OAuth users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Ledger domain models
// ---------------------------------------------------------------------------

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  apiKey        String   @unique @default(cuid())
  walletAddress String?
  balance       Float    @default(10000) // Sandbox USDC balance
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       OrganizationMember[]
  transactions  Transaction[]
  alerts        Alert[]
  alertConfigs  AlertConfig[]
}

model OrganizationMember {
  id             String @id @default(cuid())
  role           String @default("member") // owner | admin | analyst | member

  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Transaction {
  id             String   @id @default(cuid())
  organizationId String
  asset          String   @default("USDC")  // USDC | USDT | EURC | PYUSD
  amount         Float
  fromAddress    String
  toAddress      String
  network        String   @default("ethereum") // ethereum | polygon | solana
  status         String   @default("pending")  // pending | confirmed | settled | failed
  txHash         String?
  fee            Float?
  routeId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  type           String   // rate_threshold | volatility_spike | tx_confirmed
  asset          String?
  threshold      Float?
  message        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

/**
 * Persisted alert configuration per asset pair / type.
 * Enabled configs drive alert generation in the mock engine.
 */
model AlertConfig {
  id             String   @id @default(cuid())
  organizationId String
  type           String   // rate_threshold | volatility_spike
  asset          String   // e.g. "USDC/EUR"
  threshold      Float?   // For rate_threshold: fire when rate drops below this
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, asset])
}
